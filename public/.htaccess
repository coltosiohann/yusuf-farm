<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and directories resolve normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route SPA requests through the Vite entry point.
  RewriteRule ^ index.html [L]
</IfModule>
